# Nostr Dead Man's Switch — Secrets
# Copy to .env and fill in the values you need.
# Referenced in config.yaml via ${VAR_NAME} syntax.
# Only uncomment the ones your configured actions require.

# ── Bot Identity (required) ──────────────────────────────

# Bot's Nostr private key for sending warning DMs
# Generate with: docker compose run --rm deadman --generate-key
BOT_NSEC=nsec1...

# ── Email / SMTP ─────────────────────────────────────────
# Required if using email actions.
#
# Gmail:    smtp.gmail.com / 587 — use an App Password (not your login)
#           https://myaccount.google.com/apppasswords
# Fastmail: smtp.fastmail.com / 587 — use an App Password
#           https://www.fastmail.com/settings/security/tokens
#           SMTP_USER is your login (user@fastmail.com), SMTP_FROM is
#           the address you send as (you@yourdomain.com or an alias)
# Outlook:  smtp-mail.outlook.com / 587
# Proton:   127.0.0.1 / 1025 (via Proton Bridge on the same host)

# SMTP_HOST=smtp.fastmail.com
# SMTP_PORT=587
# SMTP_USER=you@fastmail.com
# SMTP_PASS=your-app-password-here
# SMTP_FROM=you@yourdomain.com

# ── ntfy ─────────────────────────────────────────────────
# Required if using ntfy push notifications.
# Public topics: https://ntfy.sh/your-secret-topic-name
# Self-hosted: https://ntfy.your-domain.com/your-topic

# NTFY_URL=https://ntfy.sh/my-deadman-switch-topic
# NTFY_TOKEN=tk_your_token_here

# ── Telegram ─────────────────────────────────────────────
# Required if using Telegram bot notifications.
# 1. Message @BotFather → /newbot → copy the token
# 2. Send /start to your new bot
# 3. Visit https://api.telegram.org/bot<TOKEN>/getUpdates
#    to find your chat_id in the response JSON

# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
# TELEGRAM_CHAT_ID=123456789

# ── Discord ──────────────────────────────────────────────
# Required if using Discord webhook notifications.
# Server Settings → Integrations → Webhooks → New Webhook → Copy URL

# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/1234567890/abcdefg...

# ── Slack ────────────────────────────────────────────────
# Required if using Slack webhook notifications.
# Create at: https://api.slack.com/messaging/webhooks

# SLACK_WEBHOOK_URL=your-slack-webhook-url-here

# ── Generic Webhook ──────────────────────────────────────
# Required if using a custom webhook with bearer auth.

# WEBHOOK_TOKEN=your-secret-token-here
