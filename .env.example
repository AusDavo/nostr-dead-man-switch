# Nostr Dead Man's Switch — Secrets only
# Copy to .env. Only passwords, tokens, and webhook URLs go here.
# Non-secret config (hosts, ports, usernames) goes directly in config.yaml.

# ── Bot Identity (required) ──────────────────────────────

# Bot's Nostr private key for sending warning DMs
# Generate with: docker compose run --rm deadman --generate-key
BOT_NSEC=nsec1...

# ── SMTP Password ────────────────────────────────────────
# Required if using email actions.
# Gmail:    https://myaccount.google.com/apppasswords
# Fastmail: https://www.fastmail.com/settings/security/tokens (SMTP scope)
# Outlook:  https://account.microsoft.com/security

# SMTP_PASS=your-app-password-here

# ── ntfy ─────────────────────────────────────────────────
# Only needed if your ntfy topic requires authentication.
# The topic URL goes in config.yaml, not here.

# NTFY_TOKEN=tk_your_token_here

# ── Telegram ─────────────────────────────────────────────
# Bot token from @BotFather. Chat ID from:
#   https://api.telegram.org/bot<TOKEN>/getUpdates

# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
# TELEGRAM_CHAT_ID=123456789

# ── Discord ──────────────────────────────────────────────
# Webhook URL contains the auth token — keep it here.
# Server Settings → Integrations → Webhooks → Copy URL

# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── Slack ────────────────────────────────────────────────
# Webhook URL contains the auth token — keep it here.
# Create at: https://api.slack.com/messaging/webhooks

# SLACK_WEBHOOK_URL=your-slack-webhook-url

# ── Generic Webhook ──────────────────────────────────────
# Bearer token for custom webhook endpoints.

# WEBHOOK_TOKEN=your-secret-token-here
