# Secrets — referenced in config.yaml via ${VAR_NAME}
# Copy to .env and fill in your values.

# Bot's private key for sending warning DMs
# Generate with: docker run --rm nostr-deadman --generate-key
BOT_NSEC=nsec1...

# SMTP password (only if using email actions)
SMTP_PASSWORD=

# Webhook token (only if using webhook actions)
WEBHOOK_TOKEN=
